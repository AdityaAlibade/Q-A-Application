# Server configurations
PORT=3000

# OpenRouter configuration
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter AI Model to use
# Examples:
# - google/gemini-2.5-flash (fast, standard)
# - google/gemini-2.5-pro (highly intelligent)
# - deepseek/deepseek-chat (coder/chat friendly)
AI_MODEL=google/gemini-2.5-flash

# Site metadata (required for OpenRouter ranking metrics)
SITE_URL=http://localhost:3000
